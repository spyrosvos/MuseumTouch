  m_text: "\u03A1\u03B1\u03C0\u03C4\u03BF\u03BC\u03B7\u03C7\u03B1\u03BD\u03AE Singer.
    \u03A7\u03C1\u03B7\u03C3\u03B9\u03BC\u03BF\u03C0\u03BF\u03B9\u03B5\u03AF\u03C4\u03B1\u03B9
    \u03B3\u03B9\u03B1 \u03C4\u03BF \u03C1\u03AC\u03C8\u03B9\u03BC\u03BF \u03BA\u03B1\u03B9
    \u03C4\u03B9\u03C2 \u03B5\u03C0\u03B9\u03B4\u03B9\u03BF\u03C1\u03B8\u03CE\u03C3\u03B5\u03B9\u03C2
    \u03C4\u03C9\u03BD \u03C1\u03BF\u03CD\u03C7\u03C9\u03BD. \u03A4\u03B7 \u03C7\u03B5\u03B9\u03C1\u03AF\u03B6\u03BF\u03BD\u03C4\u03B1\u03B9
    \u03BA\u03C5\u03C1\u03AF\u03C9\u03C2 \u03B7 \u03BA\u03C5\u03C1\u03AF\u03B1 \u03C4\u03BF\u03C5
    \u03C3\u03C0\u03B9\u03C4\u03B9\u03BF\u03CD, \u03BA\u03B1\u03B8\u03CE\u03C2 \u03BF\u03B9
    \u03B2\u03B5\u03BB\u03CC\u03BD\u03B5\u03C2 \u03B5\u03AF\u03BD\u03B1\u03B9 \u03B4\u03C5\u03C3\u03B5\u03CD\u03C1\u03B5\u03C4\u03B5\u03C2."
