  m_text: "\u03A7\u03B5\u03B9\u03C1\u03BF\u03BA\u03AF\u03BD\u03B7\u03C4\u03B7 \u03C0\u03B1\u03B3\u03C9\u03C4\u03BF\u03BC\u03B7\u03C7\u03B1\u03BD\u03AE
