  m_text: "\u039D\u03B5\u03C3\u03B5\u03C3\u03AD\u03C1 \u03C4\u03B1\u03BE\u03B9\u03B4\u03B9\u03BF\u03CD.
    \u03A0\u03B5\u03C1\u03B9\u03B5\u03AF\u03C7\u03B5 \u03B5\u03AF\u03B4\u03B7 \u03C0\u03C1\u03BF\u03C3\u03C9\u03C0\u03B9\u03BA\u03AE\u03C2
