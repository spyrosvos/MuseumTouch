  m_text: "\u03A4\u03B1 \u03BD\u03B1\u03C5\u03C4\u03B9\u03BA\u03AC \u03BC\u03BF\u03BD\u03C4\u03AD\u03BB\u03B1
    \u03B5\u03AF\u03BD\u03B1\u03B9 \u03C3\u03CD\u03BC\u03B2\u03BF\u03BB\u03B1 \u03C4\u03B7\u03C2
