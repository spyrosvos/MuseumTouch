  m_text: "\u03A0\u03C1\u03B9\u03BD \u03BB\u03AF\u03B3\u03B5\u03C2 \u03B7\u03BC\u03AD\u03C1\u03B5\u03C2
    \u03AD\u03C6\u03C4\u03B1\u03C3\u03B5 \u03C3\u03C4\u03B7\u03BD \u03B5\u03C6\u03B7\u03BC\u03B5\u03C1\u03AF\u03B4\u03B1
    \u03BC\u03B1\u03C2 \u03BC\u03B9\u03B1 \u03B1\u03BD\u03CE\u03BD\u03C5\u03BC\u03B7
    \u03B5\u03C0\u03B9\u03C3\u03C4\u03BF\u03BB\u03AE.\n\u039F \u03C3\u03C5\u03BD\u03C4\u03AC\u03BA\u03C4\u03B7\u03C2
    \u03C4\u03B7\u03C2 \u03B9\u03C3\u03C7\u03C5\u03C1\u03AF\u03B6\u03B5\u03C4\u03B1\u03B9
    \u03CC\u03C4\u03B9 \u03C0\u03AF\u03C3\u03C9 \u03B1\u03C0\u03CC \u03BC\u03AF\u03B1
    \u03B1\u03C0\u03CC \u03C4\u03B9\u03C2 \u03C3\u03B7\u03BC\u03B1\u03BD\u03C4\u03B9\u03BA\u03CC\u03C4\u03B5\u03C1\u03B5\u03C2
    \u03C6\u03B9\u03BB\u03B1\u03BD\u03B8\u03C1\u03C9\u03C0\u03B9\u03BA\u03AD\u03C2
    \u03B4\u03C9\u03C1\u03B5\u03AD\u03C2 \u03C4\u03B7\u03C2 \u03C0\u03CC\u03BB\u03B7\u03C2
    \u03BA\u03C1\u03CD\u03B2\u03B5\u03C4\u03B1\u03B9 \u03AD\u03BD\u03B1\u03C2 \u03B5\u03C5\u03B5\u03C1\u03B3\u03AD\u03C4\u03B7\u03C2
    \u03C0\u03BF\u03C5 \u03B4\u03B5\u03BD \u03B1\u03BD\u03B1\u03B3\u03BD\u03C9\u03C1\u03AF\u03C3\u03C4\u03B7\u03BA\u03B5
    \u03C0\u03BF\u03C4\u03AD \u03B4\u03B7\u03BC\u03CC\u03C3\u03B9\u03B1.\n\u039F\u03B9
    \u03B4\u03B9\u03B1\u03B8\u03AD\u03C3\u03B9\u03BC\u03B5\u03C2 \u03C0\u03BB\u03B7\u03C1\u03BF\u03C6\u03BF\u03C1\u03AF\u03B5\u03C2
    \u03BF\u03B4\u03B7\u03B3\u03BF\u03CD\u03BD \u03C3\u03B5 \u03B4\u03B9\u03B1\u03C6\u03BF\u03C1\u03B5\u03C4\u03B9\u03BA\u03AC
    \u03C0\u03C1\u03CC\u03C3\u03C9\u03C0\u03B1 \u03BA\u03B1\u03B9 \u03BA\u03B1\u03BC\u03AF\u03B1
    \u03C0\u03B7\u03B3\u03AE \u03B4\u03B5\u03BD \u03B1\u03C1\u03BA\u03B5\u03AF \u03B1\u03C0\u03CC
    \u03BC\u03CC\u03BD\u03B7 \u03C4\u03B7\u03C2 \u03B3\u03B9\u03B1 \u03BD\u03B1 \u03B1\u03C0\u03BF\u03BA\u03B1\u03BB\u03CD\u03C8\u03B5\u03B9
    \u03C4\u03B7\u03BD \u03B1\u03BB\u03AE\u03B8\u03B5\u03B9\u03B1. \u039C\u03CC\u03BD\u03BF
    \u03C3\u03C5\u03BD\u03B4\u03C5\u03AC\u03B6\u03BF\u03BD\u03C4\u03B1\u03C2 \u03C4\u03B1
    \u03C4\u03B5\u03BA\u03BC\u03AE\u03C1\u03B9\u03B1 \u03B1\u03C0\u03CC \u03CC\u03BB\u03B1
    \u03C4\u03B1 \u03BA\u03C4\u03AE\u03C1\u03B9\u03B1 \u03B8\u03B1 \u03BC\u03C0\u03BF\u03C1\u03AD\u03C3\u03B5\u03C4\u03B5
    \u03BD\u03B1 \u03BA\u03B1\u03C4\u03B1\u03BB\u03AE\u03BE\u03B5\u03C4\u03B5 \u03C3\u03C4\u03BF\u03BD
    \u03C0\u03C1\u03B1\u03B3\u03BC\u03B1\u03C4\u03B9\u03BA\u03CC \u03B5\u03C5\u03B5\u03C1\u03B3\u03AD\u03C4\u03B7.
    \n\n\u0391\u03BD\u03B1\u03BA\u03B1\u03BB\u03CD\u03C8\u03C4\u03B5 \u03C0\u03BF\u03B9\u03BF\u03C2
    \u03B2\u03C1\u03AF\u03C3\u03BA\u03B5\u03C4\u03B1\u03B9 \u03C0\u03C1\u03B1\u03B3\u03BC\u03B1\u03C4\u03B9\u03BA\u03AC
