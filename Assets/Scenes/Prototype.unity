  m_text: "\u0391\u03C3\u03B9\u03B1\u03C4\u03B9\u03BA\u03CC \u03B1\u03B3\u03B1\u03BB\u03BC\u03B1\u03C4\u03AF\u03B4\u03B9\u03BF.
